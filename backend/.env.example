# ===== LawCopilot 环境配置 =====
# 复制此文件为 .env 并填写实际值

# ===== LLM (DeepSeek / 生成式模型，用于回答) =====
LLM_API_KEY=sk-your-deepseek-api-key-here
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096

# ===== Embedding 模型 (⚠️ 向量编码专用，不是 LLM！) =====
#
# 方式一（推荐）：本地 FastEmbed + Jina/BGE（免费、隐私安全、纯CPU）
EMBEDDING_PROVIDER=local
# ⭐ FastEmbed 原生支持的中文模型（必须在白名单内，否则报错）:
#   jinaai/jina-embeddings-v2-base-zh  → 1024维, 8K上下文, 中英混合 (★推荐)
#   BAAI/bge-small-zh-v1.5          → 512维,  ~90MB, 纯中文(最轻)
#
# ❌ 以下模型不在 FastEmbed 白名单中！如需使用请改 EMBEDDING_PROVIDER=sentence_transformer:
#   BAAI/bge-large-zh-v1.5          → 用 ST 后端
#   BAAI/bge-m3                     → 用 ST 后端
EMBEDDING_MODEL=jinaai/jina-embeddings-v2-base-zh
EMBEDDING_DIMENSIONS=1024
#
# 方式二：云 API（智谱推荐 — 与国内网络友好）
# EMBEDDING_PROVIDER=openai_api
# EMBEDDING_API_KEY=your-zhipu-api-key-here
# EMBEDDING_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# EMBEDDING_MODEL=embedding-3
# EMBEDDING_DIMENSIONS=1024

# ===== Qdrant 向量数据库 =====
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=law_copilot_laws
QDRANT_VECTOR_SIZE=1024  # ⚠️ 必须与 EMBEDDING_DIMENSIONS 一致！

# ===== RAG 参数 =====
CHUNK_SIZE=512
CHUNK_OVERLAP=100
TOP_K=5
SCORE_THRESHOLD=0.3

# ===== 数据目录 =====
DATA_DIR=./data/laws
UPLOAD_DIR=./data/uploads

# ===== 调试模式 =====
DEBUG=true
